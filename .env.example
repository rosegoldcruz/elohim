# -----------------------------------------------------------------------------
# AEON AI Video Generation Platform - Environment Variables
# -----------------------------------------------------------------------------
# App Configuration
NEXT_PUBLIC_APP_URL='http://localhost:3000'
BACKEND_URL='http://localhost:8000'
APP_ENV='development'

# -----------------------------------------------------------------------------
# Subscriptions (Stripe)
# -----------------------------------------------------------------------------
# STRIPE_API_KEY is required. Set this in your local .env file, do not commit real keys!
STRIPE_API_KEY="sk_test_your_stripe_secret_key_here"
STRIPE_WEBHOOK_SECRET="whsec_your_stripe_webhook_secret_here"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_API="pk_test_your_stripe_publishable_key_here"

# Stripe Product IDs
NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID="price_your_pro_monthly_price_id"
NEXT_PUBLIC_STRIPE_PRO_YEARLY_PRICE_ID="price_your_pro_yearly_price_id"
NEXT_PUBLIC_STRIPE_CREATOR_MONTHLY_PRICE_ID="price_your_creator_monthly_price_id"
NEXT_PUBLIC_STRIPE_CREATOR_YEARLY_PRICE_ID="price_your_creator_yearly_price_id"
NEXT_PUBLIC_STRIPE_STUDIO_MONTHLY_PRICE_ID="price_your_studio_monthly_price_id"
NEXT_PUBLIC_STRIPE_STUDIO_YEARLY_PRICE_ID="price_your_studio_yearly_price_id"

# -----------------------------------------------------------------------------
# AI Platform APIs (AEON 7-Agent System)
# -----------------------------------------------------------------------------
REPLICATE_API_TOKEN="r8_your_replicate_token_here"
OPENAI_API_KEY="sk-your_openai_key_here"
ELEVENLABS_API_KEY="sk_your_elevenlabs_key_here"

# -----------------------------------------------------------------------------
# Vercel Blob Storage
# -----------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_your_token_here"

# -----------------------------------------------------------------------------
# Supabase Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"

# -----------------------------------------------------------------------------
# Analytics (PostHog)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY="phc_your_posthog_key_here"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# -----------------------------------------------------------------------------
# Admin Configuration
# -----------------------------------------------------------------------------
ADMIN_EMAIL="admin@aeon.ai,root@aeon.ai"

# -----------------------------------------------------------------------------
# LLM Configuration (Docker Model Runner)
# -----------------------------------------------------------------------------
LLM_MODE="openai"
LOCAL_LLM_HOST="http://localhost:12434"